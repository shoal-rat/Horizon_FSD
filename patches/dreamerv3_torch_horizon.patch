+    # ---- async learner (Horizon FSD) -------------------------------------
+    def _ensure_learner(self):
+        """Start the background training thread once. It trains continuously but PACED to
+        the train_ratio budget (grad steps <= env_steps * train_ratio / batch_steps), so it
+        catches up using idle GPU time (the multi-second resets, the per-tick sleeps) without
+        hogging the GPU while the car is actively driving."""
+        if self._learner_thread is not None:
+            return
+        batch_steps = self._config.batch_size * self._config.batch_length
+        per_step = self._config.train_ratio / batch_steps
+        base_step, base_update = self._step, self._update_count
+
+        def _loop():
+            while not self._learner_stop.is_set():
+                budget = (self._step - base_step) * per_step
+                if (self._update_count - base_update) < budget:
+                    self._safe_train()
+                else:
+                    self._learner_stop.wait(0.05)                 # at budget -> yield the GPU to control
+
+        self._learner_thread = threading.Thread(target=_loop, name="dreamer-learner", daemon=True)
+        self._learner_thread.start()
+        print("[async] background learner started: control loop runs free; training paced to train_ratio")
+
+    def _safe_train(self):
+        try:
+            data = next(self._dataset)
+            with self._train_lock:              # held so a checkpoint snapshot can't read mid-step params
+                self._train(data)
+            self._update_count += 1
+        except Exception:
+            traceback.print_exc()
+            self._learner_stop.wait(0.5)        # don't spin-loop on a transient error
+
+    def snapshot_for_save(self):
+        """Checkpoint dict taken UNDER the train lock, so the learner isn't mid optimizer.step when we
+        read params/optimizer state - otherwise the save is torn (some tensors pre-step, moments
+        inconsistent) and the tolerant loader accepts the corruption silently."""
+        with self._train_lock:
+            return {
+                "agent_state_dict": {k: v.detach().cpu() for k, v in self.state_dict().items()},
+                "optims_state_dict": tools.recursively_collect_optim_state_dict(self),
+            }
+
+    def stop_learner(self):
+        self._learner_stop.set()
+        if self._learner_thread is not None:
+            self._learner_thread.join(timeout=30)
+            self._learner_thread = None
 
 

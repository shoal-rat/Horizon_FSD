+"""
+Bridge: expose Horizon FSD's real-time env to NM512 dreamer's make_env.
+"""
+import os
+import sys
+
+_HFSD = os.environ.get("HORIZON_FSD_DIR", r"C:\Horizon_FSD")
+if _HFSD not in sys.path:
+    sys.path.insert(0, _HFSD)
+
+from forza_rl_env import ForzaDriveEnv  # noqa: E402,F401

+def load_new_episodes(directory, episodes, prefix="recovery-"):
+    """Load externally written replay episodes into an existing cache.
+
+    Horizon FSD writes AutoDrive recovery demonstrations directly from env.reset().
+    Dreamer's sampler reads from the in-memory cache, so newly written files need
+    to be merged for the current run to learn from them.
+    """
+    directory = pathlib.Path(directory).expanduser()
+    # Horizon FSD: recovery demos persist in a SIBLING dir (recovery_eps) that train_eps cleanup
+    # sweeps never touch - all 86 collected demos were once lost to a train_eps purge.
+    scan_dirs = [directory, directory.parent / "recovery_eps"]
+    added = 0
+    steps = 0
+    for d in scan_dirs:
+        if not d.exists():
+            continue
+        for filename in sorted(d.glob(f"{prefix}*.npz")):
+            key = os.path.splitext(os.path.basename(filename))[0]
+            if key in episodes:
+                continue
+            try:
+                with filename.open("rb") as f:
+                    episode = np.load(f)
+                    episode = {k: episode[k] for k in episode.keys()}
+            except Exception as e:
+                print(f"Could not load external episode: {e}")
+                continue
+            episodes[key] = episode
+            added += 1
+            steps += len(episode["reward"]) - 1
+    return added, steps
